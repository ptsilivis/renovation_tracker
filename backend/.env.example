# Copy to backend/.env and fill in. Never commit the real .env.

# Deployment environment: "dev" (default) or "prod". On the real host set this to
# "prod" — the app then REFUSES TO BOOT if JWT_SECRET is the dev default / too
# short or COOKIE_SECURE is false. Leave unset (dev) for local work.
RENOHUB_ENV=dev

# SQLAlchemy URL (psycopg v3 driver). Local dev via docker-compose. Use a SEPARATE
# database for dev and prod — never point a dev checkout at the live prod DB.
DATABASE_URL=postgresql+psycopg://renovation:renovation@localhost:5432/renovation

# JWT signing secret — generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
# Must be >= 32 chars and not the default when RENOHUB_ENV=prod.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# Must be true in production (Cloudflare Tunnel serves HTTPS) so the auth cookie is Secure.
COOKIE_SECURE=false

# Where uploaded files (photos, GLB, receipts) are stored on disk.
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Initial password for the seeded demo accounts (change after first login).
SEED_PASSWORD=renohub2026

# Accounts to create (all admin), as "email:Name" comma-separated. Put your real
# family/team emails HERE, never in seed.py — this file is gitignored. New
# accounts must set their own password on first login. Empty = a demo admin.
# SEED_USERS=alice@example.com:Alice, bob@example.com:Bob
